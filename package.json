{
  "name": "brand-data-fetch",
  "version": "1.0.0",
  "private": true,
  "description": "Build clothing brand dataset from Wikidata + Clearbit logo URLs",
  "main": "build_clothing_brands.js",
  "scripts": {
    "build-data": "node build_clothing_brands.js",
    "build": "npm run build-data && webpack --mode=production && node -e \"require('fs').copyFileSync('clothing_brands_4000.json', 'dist/clothing_brands_4000.json')\"",
    "start": "webpack serve --mode=development"
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "babel-loader": "^10.1.1",
    "html-webpack-plugin": "^5.6.7",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
